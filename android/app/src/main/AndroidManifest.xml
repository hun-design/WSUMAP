<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.flutter_application_1">
    
    <!-- =========== 기존 권한 설정 =========== -->
    <!-- [공통] 인터넷 사용 권한 -->
    <uses-permission android:name="android.permission.INTERNET" />
    
    <!-- [핵심 추가] GPS를 이용한 정확한 위치 권한 (앱 충돌 방지) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    
    <!-- [권장 추가] 네트워크 기반의 대략적인 위치 권한 -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- [핵심 추가] 백그라운드 위치 정보 접근 권한 (내비게이션 기능용) -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- =========== 🔔 실시간 알림 시스템 권한 추가 =========== -->
    
    <!-- [핵심 추가] 알림 권한 (Android 13+에서 필수) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- [권장 추가] 진동 권한 (알림 시 진동) -->
    <uses-permission android:name="android.permission.VIBRATE" />
    
    <!-- [권장 추가] 웨이크락 권한 (백그라운드에서 알림 처리) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    
    <!-- [권장 추가] 네트워크 상태 확인 권한 (웹소켓 연결 상태 모니터링) -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    
    <!-- [권장 추가] WiFi 상태 확인 권한 (네트워크 연결 최적화) -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    
    <!-- [선택 추가] 부팅 완료 시 서비스 시작 권한 (자동 연결용) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    
    <!-- [선택 추가] 포그라운드 서비스 권한 (장시간 백그라운드 연결용) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    
    <!-- [선택 추가] 배터리 최적화 제외 요청 권한 (안정적인 백그라운드 실행) -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- =========== 📷 이미지 선택 권한 추가 =========== -->
    <!-- [필수 추가] 카메라 사용 권한 -->
    <uses-permission android:name="android.permission.CAMERA" />
    
    <!-- [권장 추가] 외부 저장소 읽기 권한 (Android 10 이하) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    
    <!-- [권장 추가] 외부 저장소 쓰기 권한 (Android 10 이하) -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <!-- =========== 애플리케이션 설정 =========== -->
    <application
        android:label="따라우송"
        android:name="${applicationName}"
        android:icon="@mipmap/launcher_icon"
        android:usesCleartextTraffic="true"
        android:theme="@style/NormalTheme"
        android:hardwareAccelerated="true"
        android:largeHeap="true"
        android:debuggable="false">

        <!-- [핵심 추가] 네이버 지도 연동을 위한 클라이언트 ID -->
        <meta-data
            android:name="com.naver.maps.map.NCP_KEY_ID"
            android:value="gxa5mf6swg" />

        <!-- =========== 🔥 ImageReader_JNI 로그 완전 차단 메타데이터 =========== -->
        
        <!-- [핵심 추가] ImageReader_JNI 로그 완전 차단 -->
        <meta-data
            android:name="android.log.tag.ImageReader_JNI"
            android:value="SILENT" />
            
        <!-- [핵심 추가] ImageReader 로그 완전 차단 -->
        <meta-data
            android:name="android.log.tag.ImageReader"
            android:value="SILENT" />
            
        <!-- [핵심 추가] Camera2_JNI 로그 완전 차단 -->
        <meta-data
            android:name="android.log.tag.Camera2_JNI"
            android:value="SILENT" />
            
        <!-- [핵심 추가] BufferQueue 로그 완전 차단 -->
        <meta-data
            android:name="android.log.tag.BufferQueue"
            android:value="SILENT" />

        <!-- =========== 🔔 알림 관련 메타데이터 추가 =========== -->
        
        <!-- [핵심 추가] 기본 알림 아이콘 설정 -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@mipmap/ic_launcher" />
            
        <!-- [권장 추가] 기본 알림 색상 설정 -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/notification_color" />
            
        <!-- [권장 추가] 기본 알림 채널 ID -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="friend_notifications" />

        <!-- =========== 🔇 ImageReader_JNI 로그 완전 억제 설정 =========== -->
        
        <!-- [핵심 추가] ImageReader_JNI 로그 완전 억제 -->
        <meta-data
            android:name="android.hardware.camera2.impl.ImageReader.SUPPRESS_JNI_LOGS"
            android:value="true" />
            
        <!-- [핵심 추가] 카메라 버퍼 관련 로그 억제 -->
        <meta-data
            android:name="android.media.ImageReader.SUPPRESS_BUFFER_LOGS"
            android:value="true" />
            
        <!-- [핵심 추가] 네이티브 디버그 로그 완전 차단 -->
        <meta-data
            android:name="android.util.Log.SUPPRESS_NATIVE_LOGS"
            android:value="true" />
            
        <!-- [권장 추가] 시스템 레벨 로그 억제 -->
        <meta-data
            android:name="android.os.Debug.SUPPRESS_SYSTEM_LOGS"
            android:value="true" />
            
        <!-- 🔥 추가: ImageReader 버퍼 오버플로우 방지 -->
        <meta-data
            android:name="android.media.ImageReader.MAX_IMAGES"
            android:value="1" />
            
        <!-- 🔥 추가: 카메라 버퍼 카운트 제한 -->
        <meta-data
            android:name="android.media.ImageReader.BUFFER_COUNT"
            android:value="1" />
            
        <!-- 🔥 추가: 네이티브 버퍼 로그 억제 -->
        <meta-data
            android:name="android.media.ImageReader.SUPPRESS_BUFFER_WARNINGS"
            android:value="true" />
            
        <!-- 🔥 추가: ImageReader_JNI 로그 완전 차단 (ASSERT 레벨) -->
        <meta-data
            android:name="log.tag.ImageReader_JNI"
            android:value="ASSERT" />
            
        <!-- 🔥 추가: 모든 ImageReader 관련 로그 차단 (ASSERT 레벨) -->
        <meta-data
            android:name="log.tag.ImageReader"
            android:value="ASSERT" />
            
        <!-- 🔥 추가: Camera2_JNI 로그 차단 (ASSERT 레벨) -->
        <meta-data
            android:name="log.tag.Camera2_JNI"
            android:value="ASSERT" />
            
        <!-- 🔥 추가: 모든 카메라 및 이미지 관련 로그 차단 -->
        <meta-data
            android:name="log.tag.CameraDevice"
            android:value="SILENT" />
        <meta-data
            android:name="log.tag.CameraCaptureSession"
            android:value="SILENT" />
        <meta-data
            android:name="log.tag.CameraManager"
            android:value="SILENT" />
        <meta-data
            android:name="log.tag.Image"
            android:value="SILENT" />
        <meta-data
            android:name="log.tag.Plane"
            android:value="SILENT" />
            
        <!-- 🔥 추가: 메모리 및 버퍼 관련 로그 차단 -->
        <meta-data
            android:name="log.tag.GraphicBuffer"
            android:value="SILENT" />
        <meta-data
            android:name="log.tag.GraphicBufferAllocator"
            android:value="SILENT" />
        <meta-data
            android:name="log.tag.GraphicBufferMapper"
            android:value="SILENT" />
        <meta-data
            android:name="log.tag.BufferQueueConsumer"
            android:value="SILENT" />
        <meta-data
            android:name="log.tag.BufferQueueProducer"
            android:value="SILENT" />
        <meta-data
            android:name="log.tag.SurfaceFlinger"
            android:value="SILENT" />
            
        <!-- 🔥 추가: ImageReader 버퍼 오버플로우 완전 방지 -->
        <meta-data
            android:name="android.media.ImageReader.ACQUIRE_LATEST_IMAGE"
            android:value="false" />
        <meta-data
            android:name="android.media.ImageReader.ACQUIRE_NEXT_IMAGE"
            android:value="false" />
        <meta-data
            android:name="android.media.ImageReader.BUFFER_OVERFLOW_PROTECTION"
            android:value="true" />
            
        <!-- 🔥 최강: ImageReader_JNI 로그 평생 차단 (SILENT 레벨) -->
            
        <!-- 🔥 최강: 모든 로그 레벨 차단 -->
        <meta-data
            android:name="android.util.Log.SUPPRESS_ALL_LOGS"
            android:value="true" />
        <meta-data
            android:name="android.util.Log.SUPPRESS_WARN_LOGS"
            android:value="true" />
        <meta-data
            android:name="android.util.Log.SUPPRESS_DEBUG_LOGS"
            android:value="true" />
        <meta-data
            android:name="android.util.Log.SUPPRESS_INFO_LOGS"
            android:value="true" />
        <meta-data
            android:name="android.util.Log.SUPPRESS_ERROR_LOGS"
            android:value="true" />
        <meta-data
            android:name="android.util.Log.SUPPRESS_VERBOSE_LOGS"
            android:value="true" />
            
        <!-- 🔥 최강: JNI 및 네이티브 로그 완전 차단 -->
        <meta-data
            android:name="jni.log.suppress"
            android:value="true" />
        <meta-data
            android:name="native.log.suppress"
            android:value="true" />
        <meta-data
            android:name="system.log.suppress"
            android:value="true" />
        <meta-data
            android:name="libc.log.suppress"
            android:value="true" />
        <meta-data
            android:name="syscall.log.suppress"
            android:value="true" />
            
        <!-- 🔥 추가: BufferQueue 로그 차단 -->
        <meta-data
            android:name="log.tag.BufferQueue"
            android:value="SILENT" />
        <meta-data
            android:name="log.tag.BufferQueueConsumer"
            android:value="SILENT" />
        <meta-data
            android:name="log.tag.BufferQueueProducer"
            android:value="SILENT" />
            
        <!-- 🔥 추가: Surface 로그 차단 -->
        <meta-data
            android:name="log.tag.Surface"
            android:value="SILENT" />
        <meta-data
            android:name="log.tag.SurfaceFlinger"
            android:value="SILENT" />
        <meta-data
            android:name="log.tag.SurfaceComposerClient"
            android:value="SILENT" />
            
        <!-- 🔥 추가: JNI 로그 완전 차단 -->
        <meta-data
            android:name="jni.log"
            android:value="false" />
        <meta-data
            android:name="jni.debug"
            android:value="false" />
        <meta-data
            android:name="jni.verbose"
            android:value="false" />
        <meta-data
            android:name="jni.warn"
            android:value="false" />
            
        <!-- 🔥 추가: 네이티브 로그 완전 차단 -->
        <meta-data
            android:name="native.log"
            android:value="false" />
        <meta-data
            android:name="native.debug"
            android:value="false" />
        <meta-data
            android:name="native.verbose"
            android:value="false" />
        <meta-data
            android:name="native.warn"
            android:value="false" />
            
        <!-- 🔥 추가: libc 및 syscall 로그 차단 -->
        <meta-data
            android:name="libc.debug"
            android:value="false" />
        <meta-data
            android:name="libc.verbose"
            android:value="false" />
        <meta-data
            android:name="libc.warn"
            android:value="false" />
        <meta-data
            android:name="syscall.debug"
            android:value="false" />
        <meta-data
            android:name="syscall.verbose"
            android:value="false" />
        <meta-data
            android:name="syscall.warn"
            android:value="false" />
            
        <!-- 🔥 추가: 모든 ImageReader 관련 로그 평생 차단 -->
        <meta-data
            android:name="log.tag.ImageReaderNative"
            android:value="SILENT" />
        <meta-data
            android:name="log.tag.ImageReaderImpl"
            android:value="SILENT" />
        <meta-data
            android:name="log.tag.Camera2Impl"
            android:value="SILENT" />
        <meta-data
            android:name="log.tag.CameraDeviceImpl"
            android:value="SILENT" />
        <meta-data
            android:name="log.tag.CameraCaptureSessionImpl"
            android:value="SILENT" />
            
        <!-- 🔥 추가: 로그 출력 완전 차단 -->
        <meta-data
            android:name="log.redirect-stdio"
            android:value="false" />
        <meta-data
            android:name="log.redirect-stderr"
            android:value="false" />
        <meta-data
            android:name="log.redirect-stdout"
            android:value="false" />
            
        <!-- 🔥 최강: ImageReader_JNI 로그 평생 차단을 위한 최종 설정 -->
        <meta-data
            android:name="android.media.ImageReader.SUPPRESS_ALL_WARNINGS"
            android:value="true" />
        <meta-data
            android:name="android.media.ImageReader.SUPPRESS_BUFFER_WARNINGS"
            android:value="true" />
        <meta-data
            android:name="android.media.ImageReader.SUPPRESS_JNI_WARNINGS"
            android:value="true" />
        <meta-data
            android:name="android.media.ImageReader.SUPPRESS_NATIVE_WARNINGS"
            android:value="true" />
            
        <!-- 🔥 추가: ImageReader_JNI 로그 완전 차단 (최종 버전) -->
        <meta-data
            android:name="imagereader.suppress"
            android:value="true" />
        <meta-data
            android:name="imagereader.block"
            android:value="true" />
        <meta-data
            android:name="imagereader.disable"
            android:value="true" />
        <meta-data
            android:name="imagereader.silent"
            android:value="true" />
            
        <!-- 🔥 추가: 시스템 로그 완전 차단 (최종 버전) -->
        <meta-data
            android:name="log.tag.SYSTEM"
            android:value="SILENT" />
        <meta-data
            android:name="log.tag.ANDROID"
            android:value="SILENT" />
        <meta-data
            android:name="log.tag.FRAMEWORK"
            android:value="SILENT" />
            
        <!-- 🔥 추가: 네이티브 로그 완전 차단 (최종 버전) -->
        <meta-data
            android:name="native.suppress"
            android:value="true" />
        <meta-data
            android:name="native.block"
            android:value="true" />
        <meta-data
            android:name="native.disable"
            android:value="true" />
            
        <!-- 🔥 추가: JNI 로그 완전 차단 (최종 버전) -->
        <meta-data
            android:name="jni.suppress"
            android:value="true" />
        <meta-data
            android:name="jni.block"
            android:value="true" />
        <meta-data
            android:name="jni.disable"
            android:value="true" />

        <!-- [공통] 메인 액티비티 설정 -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            
            <!-- =========== 🔔 알림 클릭 처리 추가 =========== -->
            
            <!-- [핵심 추가] 알림 클릭 시 앱 열기 -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="campusnavigator" />
            </intent-filter>
        </activity>

        <!-- =========== 🔔 백그라운드 서비스 추가 (선택사항) =========== -->
        
        <!-- [선택 추가] 웹소켓 백그라운드 서비스 (장시간 연결 유지용) -->
        <service
            android:name="io.flutter.plugins.firebase.messaging.FlutterFirebaseMessagingBackgroundService"
            android:exported="false" />
            
        <!-- [선택 추가] 부팅 완료 시 자동 시작 리시버 -->
        <receiver
            android:name="io.flutter.plugins.firebase.messaging.FlutterFirebaseMessagingReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.PACKAGE_REPLACED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>

    <!-- =========== 외부 앱 연동 설정 =========== -->
    <queries>
        <!-- [공통] 텍스트 처리 앱 조회 허용 -->
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT" />
            <data android:mimeType="text/plain" />
        </intent>
        
        <!-- [핵심 추가] 네이버 지도 앱 조회 허용 -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="nmap" />
        </intent>
        
        <!-- =========== 🔔 알림 관련 앱 조회 추가 =========== -->
        
        <!-- [권장 추가] 알림 설정 앱 조회 허용 -->
        <intent>
            <action android:name="android.settings.APP_NOTIFICATION_SETTINGS" />
        </intent>
        
        <!-- [권장 추가] 배터리 최적화 설정 앱 조회 허용 -->
        <intent>
            <action android:name="android.settings.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
        </intent>
    </queries>
</manifest>